{
  "git.enableSmartCommit": true,
  "sort-imports.default-sort-style": "module-scoped",
  "cSpell.userWords": [
    "API's",
    "autodocs",
    "clsx",
    "codebases",
    "debouncing",
    "debrand",
    "debranded",
    "disableable",
    "disableabled",
    "docgen",
    "Docstrings",
    "dotfile",
    "dotfiles",
    "estree",
    "extensionless",
    "fdir",
    "formtoken",
    "geofence",
    "geofences",
    "getenv",
    "globwalk",
    "hasher",
    "hoverable",
    "importee",
    "ints",
    "jsonify",
    "kameleon",
    "Kibana",
    "kubernetes",
    "Kwargs",
    "losslessly",
    "memfs",
    "Momondo",
    "mundi",
    "noninteractive",
    "messageformat",
    "paginators",
    "performantly",
    "permissioned",
    "permissioning",
    "personalizations",
    "Pipeable",
    "preconfigured",
    "pylint",
    "pytz",
    "rolldown",
    "scoper",
    "serializers",
    "shortcode",
    "shortcodes",
    "stylelint",
    "subheader",
    "superpedestrian",
    "Svgs",
    "symlink",
    "symlinked",
    "symlinks",
    "tailwindcss",
    "testid",
    "tinyglobby",
    "toakleaf",
    "todos",
    "topo",
    "treeify",
    "Turborepo",
    "twilio",
    "typedefs",
    "tzinfo",
    "uncompacted",
    "unmount",
    "unmounting",
    "Unplugin",
    "vals",
    "vestigo",
    "Vieweset",
    "viewports",
    "vinxi"
  ],
  "editor.tabSize": 2,
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "gitlens.blame.highlight.locations": ["gutter", "overview", "line"],
  "gitlens.blame.format": "${author|18} ${ago|14}",
  "gitlens.blame.avatars": false,
  "git.autofetch": true,
  "gitlens.recentChanges.highlight.locations": ["line", "overview", "gutter"],
  "gitlens.hovers.currentLine.over": "line",
  "workbench.iconTheme": "gruvbox-material-icon-theme",
  "editor.fontFamily": "Operator Mono Lig",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "python.formatting.autopep8Args": [
    "--max-line-length",
    "100",
    "--aggressive"
  ],
  "python.formatting.provider": "black",
  "workbench.colorTheme": "Gruvbox Dark (Hard)",
  "workbench.colorCustomizations": {
    "terminal.background": "#1d2021",
    "terminal.foreground": "#ebdbb2",
    "terminal.selectionBackground": "#665c54",
    "terminalCursor.foreground": "#ebdbb2",
    "terminal.ansiBlack": "#1d2021",
    "terminal.ansiRed": "#cc241d",
    "terminal.ansiGreen": "#98971a",
    "terminal.ansiYellow": "#d79921",
    "terminal.ansiBlue": "#458588",
    "terminal.ansiMagenta": "#b16286",
    "terminal.ansiCyan": "#689d6a",
    "terminal.ansiWhite": "#a89984",
    "terminal.ansiBrightBlack": "#928374",
    "terminal.ansiBrightRed": "#fb4934",
    "terminal.ansiBrightGreen": "#b8bb26",
    "terminal.ansiBrightYellow": "#fabd2f",
    "terminal.ansiBrightBlue": "#83a598",
    "terminal.ansiBrightMagenta": "#d3869b",
    "terminal.ansiBrightCyan": "#8ec07c",
    "terminal.ansiBrightWhite": "#ebdbb2"
  },
  "terminal.integrated.minimumContrastRatio": 1,
  "terminal.integrated.drawBoldTextInBrightColors": false,
  "terminal.integrated.env.osx": {
    "COLORTERM": "truecolor",
    "TERM": "xterm-256color"
  },
  "terminal.integrated.fontFamily": "FiraMono Nerd Font Mono",
  "terminal.integrated.fontSize": 14,
  "gitlens.codeLens.enabled": false,
  "vim.highlightedyank.enable": true,
  "vim.surround": true,
  "vim.leader": "<space>",
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"]
    },
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"]
    }
  ],
  "vim.normalModeKeyBindings": [
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<C-I>"],
      "commands": ["workbench.action.navigateForward"]
    },
    {
      "before": ["<leader>", "n"],
      "commands": ["workbench.action.splitEditor"]
    },
    {
      "before": ["<leader>", "l"],
      "commands": ["workbench.action.focusNextGroup"]
    },
    {
      "before": ["<leader>", "h"],
      "commands": ["workbench.action.focusPreviousGroup"]
    },
    {
      "before": ["<leader>", "g", "]"],
      "commands": ["editor.action.marker.nextInFiles"]
    },
    {
      "before": ["<leader>", "g", "["],
      "commands": ["editor.action.marker.prevInFiles"]
    },
    {
      "before": ["<leader>", "r", "g"],
      "commands": ["workbench.view.search"]
    },
    {
      "before": ["<leader>", "g", "s"],
      "commands": ["workbench.view.scm"]
    }
  ],
  "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx2G -Xms100m",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "explorer.confirmDelete": false,
  "prettier.printWidth": 100,
  "editor.formatOnSave": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.exclude": {
    "**/.git": false
  },
  "vim.useSystemClipboard": true,
  "prettier.requireConfig": true,
  "editor.stickyScroll.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.options": {
    "extensions": [".js", ".jsx", ".md", ".mdx", ".ts", ".tsx"]
  },
  "eslint.validate": [
    "mdx",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    {"mode": "auto"}
  ],
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "totalTypeScript.hideAllTips": false,
  "totalTypeScript.hideBasicTips": true,
  "security.workspace.trust.untrustedFiles": "open",
  "[python]": {
    "editor.formatOnType": true
  },
  "[less]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "totalTypeScript.hiddenTips": [
    "passing-generics-to-types",
    "omit-utility-type",
    "tuple-type",
    "record-utility-type",
    "generic-slots-in-functions",
    "type-alias-with-generics",
    "in-operator-narrowing",
    "partial-utility-type"
  ],
  "editor.inlineSuggest.enabled": true,
  "editor.unicodeHighlight.allowedCharacters": {
    " ": true
  },
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "yaml": true
  },
  "typescript.tsserver.log": "off",
  "editor.minimap.enabled": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "diffEditor.ignoreTrimWhitespace": true,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "git.openRepositoryInParentFolders": "always",
  "github.copilot.nextEditSuggestions.enabled": true,
  "cursor.cpp.disabledLanguages": ["plaintext", "markdown", "scminput"],
  "cursor.composer.shouldAllowCustomModes": true,
  "cursor.composer.usageSummaryDisplay": "always",
  "docker.extension.enableComposeLanguageServer": false,
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "redhat.telemetry.enabled": true,
  "window.autoDetectColorScheme": false
}
