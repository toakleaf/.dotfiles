{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#fabd2f",
          "style": "plain",
          "template": " ! ",
          "type": "root"
        },
        {
          "background": "#458588",
          "foreground": "#ebdbb2",
          "properties": {
            "max_width": 40,
            "style": "powerlevel"
          },
          "style": "plain",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#98971a",
          "background_templates": [
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#d3869b{{ end }}",
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#fabd2f{{ end }}",
            "{{ if gt .Ahead 0 }}#ebdbb2{{ end }}",
            "{{ if gt .Behind 0 }}#ebdbb2{{ end }}"
          ],
          "foreground": "#1d2021",
          "properties": {
            "branch_icon": "",
            "branch_template": "{{$length := len .Branch}}{{if gt $length 27}}{{ abbrev 15 .Branch }}{{ trunc -12 .Branch}}{{else if .Branch}}{{ .Branch }}{{else}}detached:{{ trunc 7 .HEAD }}{{ end }}",
            "fetch_status": true
          },
          "style": "plain",
          "template": " {{ .HEAD }}{{ if .Behind }} ⇣{{ .Behind }}{{ end }}{{ if .Ahead }} ⇡{{ .Ahead }}{{ end }}{{ if .Staging.Changed }} ✓{{ add .Staging.Deleted .Staging.Added .Staging.Modified }}{{ end }}{{ if .Working.Changed }} *{{ add .Working.Deleted .Working.Added .Working.Modified .Working.Untracked }}{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "segments": [
        {
          "background": "#98971a",
          "background_templates": [
            "{{ if gt .Code 0 }}#fb4934{{ end }}"
          ],
          "foreground": "#1d2021",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ebdbb2{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": " {{ if gt .Code 0 }}×{{ else }}✓{{ end }} ",
          "type": "status"
        },
        {
          "background": "#665c54",
          "foreground": "#ebdbb2",
          "properties": {
            "style": "roundrock",
            "threshold": 0
          },
          "style": "plain",
          "template": " ◷ {{ .FormattedMs }} ",
          "type": "executiontime"
        }
      ],
      "type": "rprompt"
    }
  ],
  "console_title_template": "{{.Folder}}{{if .Root}} :: root{{end}} :: {{.Shell}}",
  "final_space": true,
  "version": 3
}
